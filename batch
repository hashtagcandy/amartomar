@echo off
setlocal enabledelayedexpansion

REM Change this to your features folder
set "FEATURE_DIR=C:\path\to\features"
set "OUTPUT=ScenarioOutlines.csv"

echo Feature File,Scenario Outline > "%OUTPUT%"

for %%F in ("%FEATURE_DIR%\*.feature") do (
    echo Processing %%~nxF
    powershell -NoLogo -NoProfile -Command ^
        "Get-Content '%%F' | ForEach-Object { ^
            if ($_ -match '^\s*Scenario Outline\s*:\s*(.+)$') { ^
                $scenario = $matches[1].Trim() ^
                Add-Content '%OUTPUT%' ('%%~nxF' + ',' + $scenario) ^
            } ^
        }"
)

echo.
echo ✅ Export complete! File saved as %OUTPUT%
pause